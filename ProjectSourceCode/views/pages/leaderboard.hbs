<div class="container mt-5 d-flex justify-content-center card bg-dark text-white border-secondary shadow-lg" style="max-width: 450px; border-radius: 15px;">
    <div class="card-body p-4">
        <div class="d-flex justify-content-center  mb-4">
            <h5 class="card-title fw-bold mb-0">Leaderboard</h5>
        </div>

        {{#each topUsers}}
        <div class="user-row d-flex align-items-center justify-content-between py-3">
            <div class="d-flex align-items-center">
                <div class="fs-5 me-3 text-secondary">
                    {{#if (eq @index 0)}} <div class="text-warning">1</div>
                    {{else if (eq @index 1)}} <div class="text-light">2</div>
                    {{else if (eq @index 2)}} <div class="text-info">3</div>
                    {{else}} {{add @index 1}}
                    {{/if}}
                </div>
                <div class="fs-5 fw-medium">{{this.username}}</div>
            </div>
            <div class="text-end">
                <div class="balance-text fs-5 fw-bold">
                    ${{this.balance}}
                </div>
            </div>
        </div>
        {{else}}
            <div class="text-center text-muted py-4">
                No data available
            </div>
        {{/each}}
    </div>
</div>