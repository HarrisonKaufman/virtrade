<div class="d-flex justify-content-center align-items-center vh-100 bg-dark" data-bs-theme="dark">
  <div class="card shadow-lg p-4 bg-body-tertiary" style="width: 100%; max-width: 400px;">
    
    <form action="/register" method="POST">

      <div class="mb-4 text-center">
        <h2 class="fw-bold">Register</h2>
      </div>

      <div class="mb-3">
        <label class="form-label text-muted">Email</label>
        <input name="email" class="form-control" placeholder="Enter email">
      </div>

      <div class="mb-3">
        <label class="form-label text-muted">Username</label>
        <input name="username" class="form-control" placeholder="Enter username">
      </div>

      <div class="mb-3">
        <label class="form-label text-muted">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter password">
      </div>

      <div class="d-grid mb-3">
        <button type="submit" class="btn btn-primary fw-semibold py-2">
          Register
        </button>
      </div>

      <div class="text-center">
        <small class="text-muted">
          Already have an account?
          <a href="/login">Login</a>
        </small>
      </div>

    </form>

  </div>
</div>