<div class="d-flex justify-content-center align-items-center vh-100 bg-dark" data-bs-theme="dark">
  <div class="card shadow-lg p-4 bg-body-tertiary" style="width: 100%; max-width: 400px;">
    <form action="/register" method="POST" id="registerForm">
      <div class="mb-4 text-center">
        <h2 class="fw-bold">Register</h2>
      </div>

      {{#if error}}
      <div class="alert alert-danger py-2 text-center" style="font-size: 0.875rem;">
        {{error}}
      </div>
      {{/if}}

      <div class="mb-3">
        <label class="form-label text-muted">Email</label>
        <input name="email" id="email" class="form-control" placeholder="Enter email" autocomplete="email" value="{{body.email}}">
        <div id="emailError" class="text-danger mt-1" style="font-size: 0.8rem; display: none;">
          ✗ Please enter a valid email address
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label text-muted">Username</label>
        <input name="username" class="form-control" placeholder="Enter username" value="{{body.username}}">
      </div>
      <div class="mb-3">
        <label class="form-label text-muted">Password</label>
        <input type="password" name="password" id="password" class="form-control" placeholder="Enter password" autocomplete="new-password">
        <div class="mt-2 px-1" id="passwordRules" style="display: none;">
          <p class="mb-1 text-muted" style="font-size: 0.75rem;">Password must contain:</p>
          <ul class="list-unstyled mb-0" style="font-size: 0.8rem;">
            <li id="rule-length"  class="text-danger">✗ At least 8 characters</li>
            <li id="rule-upper"   class="text-danger">✗ One uppercase letter (A–Z)</li>
            <li id="rule-lower"   class="text-danger">✗ One lowercase letter (a–z)</li>
            <li id="rule-number"  class="text-danger">✗ One number (0–9)</li>
            <li id="rule-special" class="text-danger">✗ One special character (!@#$…)</li>
          </ul>
        </div>
      </div>
      <div class="d-grid mb-3">
        <button type="submit" id="submitBtn" class="btn btn-primary fw-semibold py-2" disabled>
          Register
        </button>
      </div>
      <div class="text-center">
        <small class="text-muted">
          Already have an account? <a href="/login">Login</a>
        </small>
      </div>
    </form>
  </div>
</div>

<!-- script block unchanged from before -->

<script>
  const passwordInput = document.getElementById('password');
  const emailInput    = document.getElementById('email');
  const submitBtn     = document.getElementById('submitBtn');
  const rulesBox      = document.getElementById('passwordRules');
  const emailError    = document.getElementById('emailError');

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const rules = [
    { id: 'rule-length',  test: v => v.length >= 8,           label: '✓ At least 8 characters',        fail: '✗ At least 8 characters' },
    { id: 'rule-upper',   test: v => /[A-Z]/.test(v),         label: '✓ One uppercase letter (A–Z)',     fail: '✗ One uppercase letter (A–Z)' },
    { id: 'rule-lower',   test: v => /[a-z]/.test(v),         label: '✓ One lowercase letter (a–z)',     fail: '✗ One lowercase letter (a–z)' },
    { id: 'rule-number',  test: v => /[0-9]/.test(v),         label: '✓ One number (0–9)',               fail: '✗ One number (0–9)' },
    { id: 'rule-special', test: v => /[^A-Za-z0-9]/.test(v), label: '✓ One special character (!@#$…)', fail: '✗ One special character (!@#$…)' },
  ];

  function checkSubmit() {
    const passwordVal  = passwordInput.value;
    const allRulesPass = rules.every(r => r.test(passwordVal));
    const emailValid   = emailRegex.test(emailInput.value);
    submitBtn.disabled = !(allRulesPass && emailValid);
  }

  passwordInput.addEventListener('input', () => {
    const val = passwordInput.value;
    rulesBox.style.display = val.length > 0 ? 'block' : 'none';

    rules.forEach(rule => {
      const el   = document.getElementById(rule.id);
      const pass = rule.test(val);
      el.textContent = pass ? rule.label : rule.fail;
      el.className   = pass ? 'text-success' : 'text-danger';
    });

    checkSubmit();
  });

  emailInput.addEventListener('input', () => {
    const valid = emailRegex.test(emailInput.value);
    emailError.style.display = emailInput.value.length > 0 && !valid ? 'block' : 'none';
    checkSubmit();
  });
</script>